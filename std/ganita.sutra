# गणित — arithmetic over the natural numbers (संख्या).
#
# Numbers are Peano terms: ० is zero, उत्तर(n) is the successor of n. The
# numeral sugar means you can write ५ instead of उत्तर(उत्तर(उत्तर(उत्तर(उत्तर(०)))))
# both in rules and in प्रयोग expressions.

अधिकार गणित।

# संख्या — the saṃjñā (type) of natural numbers.
संज्ञा संख्या := ० | उत्तर(संख्या)।

# योग — addition.
सूत्र योग(०, ?ख) -> ?ख।
सूत्र योग(उत्तर(?क), ?ख) -> उत्तर(योग(?क, ?ख))।

# गुणन — multiplication.
सूत्र गुणन(०, ?ख) -> ०।
सूत्र गुणन(उत्तर(?क), ?ख) -> योग(?ख, गुणन(?क, ?ख))।

# पूर्व — predecessor (पूर्व of ० is ०).
सूत्र पूर्व(०) -> ०।
सूत्र पूर्व(उत्तर(?क)) -> ?क।

# वियोग — truncated subtraction (monus): never goes below ०.
सूत्र वियोग(?क, ०) -> ?क।
सूत्र वियोग(०, उत्तर(?ख)) -> ०।
सूत्र वियोग(उत्तर(?क), उत्तर(?ख)) -> वियोग(?क, ?ख)।

# क्रमगुणित — factorial.
सूत्र क्रमगुणित(०) -> उत्तर(०)।
सूत्र क्रमगुणित(उत्तर(?क)) -> गुणन(उत्तर(?क), क्रमगुणित(?क))।

# तुल्य — equality of two naturals, yielding सत्य / असत्य.
सूत्र तुल्य(०, ०) -> सत्य।
सूत्र तुल्य(०, उत्तर(?ख)) -> असत्य।
सूत्र तुल्य(उत्तर(?क), ०) -> असत्य।
सूत्र तुल्य(उत्तर(?क), उत्तर(?ख)) -> तुल्य(?क, ?ख)।

# न्यूनसम — less-than-or-equal.
सूत्र न्यूनसम(०, ?ख) -> सत्य।
सूत्र न्यूनसम(उत्तर(?क), ०) -> असत्य।
सूत्र न्यूनसम(उत्तर(?क), उत्तर(?ख)) -> न्यूनसम(?क, ?ख)।
