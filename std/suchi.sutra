# सूची — lists, including the higher-order workhorses प्रति/छन्न/संहार
# (map / filter / fold).

अधिकार सूची।

# दीर्घ — length. (For strings, the native builtin दीर्घ applies instead.)
सूत्र दीर्घ(रिक्त) -> 0।
सूत्र दीर्घ(युग्म(?क, ?श)) -> 1 + दीर्घ(?श)।

# योजन — append.
सूत्र योजन(रिक्त, ?य) -> ?य।
सूत्र योजन(युग्म(?क, ?श), ?य) -> युग्म(?क, योजन(?श, ?य))।

# विपर्यय — reverse.
सूत्र विपर्यय(रिक्त) -> रिक्त।
सूत्र विपर्यय(युग्म(?क, ?श)) -> योजन(विपर्यय(?श), युग्म(?क, रिक्त))।

# शीर्ष — head; पुच्छ — tail. Empty cases yield a दोष error value.
सूत्र शीर्ष(रिक्त) -> दोष("रिक्ता सूची")।
सूत्र शीर्ष(युग्म(?क, ?श)) -> ?क।
सूत्र पुच्छ(रिक्त) -> दोष("रिक्ता सूची")।
सूत्र पुच्छ(युग्म(?क, ?श)) -> ?श।

# प्रति — map: apply ?फ to every element.
सूत्र प्रति(?फ, रिक्त) -> रिक्त।
सूत्र प्रति(?फ, युग्म(?क, ?श)) -> युग्म(?फ(?क), प्रति(?फ, ?श))।

# छन्न — filter: keep elements satisfying the predicate ?फ.
सूत्र छन्न(?फ, रिक्त) -> रिक्त।
सूत्र छन्न(?फ, युग्म(?क, ?श)) -> यदि(?फ(?क), युग्म(?क, छन्न(?फ, ?श)), छन्न(?फ, ?श))।

# संहार — left fold: संहार(f, acc, [x,y,…]) = f(f(acc, x), y) …
सूत्र संहार(?फ, ?आदि, रिक्त) -> ?आदि।
सूत्र संहार(?फ, ?आदि, युग्म(?क, ?श)) -> संहार(?फ, ?फ(?आदि, ?क), ?श)।

# सदस्य — membership; समष्टि — sum of a numeric list.
सूत्र सदस्य(?ल, रिक्त) -> असत्य।
सूत्र सदस्य(?ल, युग्म(?क, ?श)) -> वा(?ल == ?क, सदस्य(?ल, ?श))।
सूत्र समष्टि(?श) -> संहार((?आ, ?क) => ?आ + ?क, 0, ?श)।
