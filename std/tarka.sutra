# तर्क — logic. Booleans are just two constants, सत्य (true) and असत्य (false),
# and every "control structure" is an ordinary rewrite rule.

अधिकार तर्क।

# सत्यता — the saṃjñā (type) of booleans.
संज्ञा सत्यता := सत्य | असत्य।

# न — logical not.
सूत्र न(सत्य) -> असत्य।
सूत्र न(असत्य) -> सत्य।

# च — conjunction ("and"). Short-circuits on the first argument.
सूत्र च(सत्य, ?ख) -> ?ख।
सूत्र च(असत्य, ?ख) -> असत्य।

# वा — disjunction ("or").
सूत्र वा(सत्य, ?ख) -> सत्य।
सूत्र वा(असत्य, ?ख) -> ?ख।

# यदि — the conditional. Because reduction is outermost (lazy), the branch
# that is not chosen is never evaluated: `यदि` is just a three-argument rule,
# not a special form.
सूत्र यदि(सत्य, ?तदा, ?अन्यथा) -> ?तदा।
सूत्र यदि(असत्य, ?तदा, ?अन्यथा) -> ?अन्यथा।

# यमल — a demonstration of non-linear matching: two structurally equal
# arguments rewrite to "समान" (equal); otherwise the term is left stuck.
सूत्र यमल(?क, ?क) -> समान।
