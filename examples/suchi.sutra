# सूची — lists, literals, and the higher-order workhorses.
# Run: sutra run examples/suchi.sutra

प्रयोग [1, 2, 3] ++ [4, 5]।  # append
प्रयोग 0 :: [1, 2, 3]।  # cons
प्रयोग विपर्यय([1, 2, 3, 4, 5])।  # reverse
प्रयोग दीर्घ([10, 20, 30])।  # length
प्रयोग प्रति((?x) => ?x * 10, [1, 2, 3])।  # map
प्रयोग छन्न((?x) => ?x > 2, [1, 2, 3, 4, 5])।  # filter
प्रयोग संहार((?a, ?b) => ?a + ?b, 0, [1, 2, 3, 4, 5])।  # fold (sum)
प्रयोग सदस्य(3, [1, 2, 3])।  # membership
