# सूची — list examples. Run with:  sutra run examples/suchi.sutra

# A little list [१, २, ३].
प्रयोग दीर्घ(युग्म(१, युग्म(२, युग्म(३, रिक्त))))।          # length = 3
प्रयोग विपर्यय(युग्म(१, युग्म(२, युग्म(३, रिक्त))))।       # reverse
प्रयोग योजन(युग्म(१, रिक्त), युग्म(२, युग्म(३, रिक्त)))।   # append
प्रयोग शीर्ष(युग्म(९, रिक्त))।                              # head = 9
प्रयोग सदस्य(२, युग्म(१, युग्म(२, युग्म(३, रिक्त))))।       # is 2 a member?
